{{- /* layouts/_default/index.json */ -}}
{{- $.Scratch.Set "searchIndex" slice -}}
{{- $posts := where site.RegularPages "Type" "in" (slice "posts") -}}
{{- range $posts -}}
  {{- $plain := .Plain -}}
  {{- if gt (len $plain) 500 -}}
    {{- $plain = substr $plain 0 500 -}}
  {{- else -}}
    {{- $plain = .Plain -}}
  {{- end -}}
  {{- $.Scratch.Add "searchIndex" (dict
    "title" .Title
    "permalink" .Permalink
    "date" (.Date.Format "2006-01-02")
    "description" .Description
    "content" $plain
    "tags" (.Params.tags | default slice)
    "categories" (.Params.categories | default slice)
  ) -}}
{{- end -}}
{{- $.Scratch.Get "searchIndex" | jsonify -}}